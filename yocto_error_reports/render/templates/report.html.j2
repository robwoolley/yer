<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Yocto error report{% if doc.builds %} — {{ doc.builds[0].component }}{% endif %}</title>
<style>
  :root {
    color-scheme: light dark;
    --bg: #ffffff; --fg: #1b1f23; --muted: #57606a; --card: #f6f8fa;
    --border: #d0d7de; --error: #cf222e; --warning: #9a6700; --accent: #0969da;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #0d1117; --fg: #e6edf3; --muted: #8b949e; --card: #161b22;
      --border: #30363d; --error: #ff7b72; --warning: #d29922; --accent: #58a6ff;
    }
  }
  * { box-sizing: border-box; }
  body {
    margin: 0; padding: 1.5rem; max-width: 60rem; margin-inline: auto;
    background: var(--bg); color: var(--fg);
    font: 15px/1.5 -apple-system, system-ui, "Segoe UI", Helvetica, Arial, sans-serif;
    /* long unbroken tokens (paths, URLs) wrap instead of widening the page */
    overflow-wrap: anywhere;
  }
  h1 { font-size: 1.4rem; margin: 0 0 .25rem; }
  .meta { color: var(--muted); font-size: .9rem; margin: 0 0 1rem; }
  .totals { display: flex; flex-wrap: wrap; gap: .5rem; margin-bottom: 1.5rem; }
  .chip {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 999px; padding: .15rem .7rem; font-size: .85rem;
  }
  .recipe { margin: 1.25rem 0 .5rem; font-size: 1.1rem; }
  details.finding {
    background: var(--card); border: 1px solid var(--border);
    border-left: 3px solid var(--border); border-radius: 6px;
    margin: .5rem 0; padding: .25rem .75rem;
  }
  details.finding.sev-error { border-left-color: var(--error); }
  details.finding.sev-warning { border-left-color: var(--warning); }
  details.finding.cascade { margin-left: 1.5rem; opacity: .8; }
  summary { cursor: pointer; font-weight: 600; }
  summary .cat { color: var(--accent); }
  summary .conf, summary .loc { color: var(--muted); font-weight: 400; font-size: .85rem; }
  .title { margin: .5rem 0; }
  button.copy {
    background: var(--card); color: var(--accent);
    border: 1px solid var(--border); border-radius: 6px;
    padding: .2rem .6rem; font: inherit; font-size: .8rem; cursor: pointer;
  }
  button.copy:hover { border-color: var(--accent); }
  button.copy.copied { color: var(--fg); }
  pre.evidence {
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    padding: .6rem .8rem; margin: .5rem 0 .25rem; max-width: 100%;
    /* evidence keeps exact formatting: it scrolls in its own box, never wraps
       and never widens the page (overflow-wrap does not apply under pre). */
    overflow-x: auto; white-space: pre; overflow-wrap: normal; font-size: .85rem;
  }
  footer { color: var(--muted); font-size: .8rem; margin-top: 2rem; }
</style>
</head>
<body>
  <h1>Yocto error report{% if doc.builds %} — {{ doc.builds[0].component }}{% endif %}</h1>
  {% if doc.builds %}
  <p class="meta">
    {%- set b = doc.builds[0] -%}
    {% if b.machine %}machine: {{ b.machine }} · {% endif %}
    {%- if b.distro %}distro: {{ b.distro }} · {% endif %}
    {%- if b.source %}source: {{ b.source }}{% endif %}
  </p>
  {% endif %}

  <div class="totals">
    <span class="chip">{{ doc.summary.errors }} error(s)</span>
    <span class="chip">{{ doc.summary.warnings }} warning(s)</span>
    {% for cat, n in doc.summary.by_category | dictsort %}
      <span class="chip">{{ cat }}: {{ n }}</span>
    {% endfor %}
  </div>

  {% for recipe, findings in by_recipe.items() %}
    <h2 class="recipe">{{ recipe }}</h2>
    {% for f in findings %}
      <details class="finding sev-{{ f.severity }}{% if f.cascade_of %} cascade{% endif %}">
        <summary>
          <span class="cat">{{ f.category }}</span>
          {% if f.task %}<span class="loc">[{{ f.task }}]</span>{% endif %}
          <span class="conf">(confidence {{ "%.2f" | format(f.confidence) }})</span>
          {% if f.cascade_of %}<span class="loc">↳ cascade</span>{% endif %}
        </summary>
        <p class="title">{{ f.title }}
          {%- if f.file %} <span class="loc">at {{ f.file }}{% if f.line %}:{{ f.line }}{% endif %}</span>{% endif %}
        </p>
        <button class="copy" type="button" data-markdown="{{ f.copy_markdown }}">Copy for Claude</button>
        {% if f.evidence %}<pre class="evidence">{% for line in f.evidence %}{{ line }}
{% endfor %}</pre>{% endif %}
      </details>
    {% endfor %}
  {% endfor %}

  {% if not doc.findings %}<p class="meta">No findings.</p>{% endif %}

  <footer>
    Generated by yer {{ doc.tool_version }}{% if generated_at %} at {{ generated_at }}{% endif %}.
  </footer>

  <script>
  // Per-finding "Copy for Claude" (SPEC-004 §2). Inline, no network. Uses the
  // async Clipboard API where available, with an execCommand fallback for
  // insecure contexts (e.g. opening index.html over file://).
  (function () {
    function fallbackCopy(text) {
      var ta = document.createElement("textarea");
      ta.value = text;
      ta.setAttribute("readonly", "");
      ta.style.position = "absolute";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); } catch (e) { /* ignore */ }
      document.body.removeChild(ta);
    }
    function copyText(text) {
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).catch(function () { fallbackCopy(text); });
      } else {
        fallbackCopy(text);
      }
    }
    var buttons = document.querySelectorAll("button.copy");
    Array.prototype.forEach.call(buttons, function (btn) {
      btn.addEventListener("click", function (ev) {
        ev.preventDefault();
        copyText(btn.getAttribute("data-markdown") || "");
        var original = btn.textContent;
        btn.textContent = "Copied";
        btn.classList.add("copied");
        setTimeout(function () {
          btn.textContent = original;
          btn.classList.remove("copied");
        }, 1200);
      });
    });
  })();
  </script>
</body>
</html>
